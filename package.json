{
  "name": "ai-desktop-assistant",
  "version": "1.0.0",
  "description": "Assistente de IA desktop com avatar animado e voz",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "install-deps": "npm install"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.ai.desktop.assistant",
    "productName": "AI Assistant",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
