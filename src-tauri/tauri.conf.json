{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yara-personal-ai",
  "version": "0.1.0",
  "identifier": "com.yara.personal-ai",
  "build": {
    "frontendDist": "../app/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Assistant",
        "width": 400,
        "height": 700,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
