# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env

# HuggingFace — necessário para download de modelos privados / rate limit maior
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Anthropic — necessário se usar provider: "anthropic" em config.json
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
